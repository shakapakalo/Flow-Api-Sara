# ============================================================
# Flow by RSA - Environment Variables
# Copy this file to .env in project root and fill in values
# cp vps/.env.example .env
# ============================================================

# ---- Database (PostgreSQL) ----
# Get this from setup.sh output or /root/db-credentials.txt
DATABASE_URL=postgresql://flowrsa:YOUR_DB_PASS@localhost:5432/flowrsa

# ---- Auth / Security ----
# Generate a random secret: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-random-secret-string

# ---- App Settings ----
NODE_ENV=production

# ---- Email (Optional - for notifications) ----
# Leave blank to disable email features
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
