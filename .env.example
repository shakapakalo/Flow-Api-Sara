# ─────────────────────────────────────────────
#  Flow by RSA — Environment Variables Example
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=changeme123

# JWT / session secret — use a long random string
SESSION_SECRET=replace-with-a-long-random-secret-string

# Flow2API API key (must match what you set in flow2api)
FLOW2API_API_KEY=han1234

# Ports exposed on host (default: 80 and 443)
HTTP_PORT=80
HTTPS_PORT=443
